# Connect any OpenAI-compatible hosted provider serving an open model.
# Do not commit real keys. Add these three values in Vercel's Environment Variables.
AI_BASE_URL=https://your-provider.example/v1
AI_API_KEY=replace-with-your-provider-key
AI_MODEL=your-open-model-name

# WM ID via Supabase. These are public browser connection values, never a secret or service-role key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-with-your-key
